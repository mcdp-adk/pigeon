{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "./settings.schema.json",
  "title": "Pigeon settings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "telegram",
    "ai",
    "sandbox"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "telegram": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "explicit_only",
        "allowed_chats"
      ],
      "properties": {
        "proxy": {
          "type": "string",
          "description": "Optional HTTP(S) or SOCKS5 proxy URL"
        },
        "explicit_only": {
          "type": "boolean",
          "description": "Require explicit command, mention, or bot reply trigger before handling messages"
        },
        "allowed_chats": {
          "type": "object",
          "description": "Map of allowed Telegram chat IDs to optional per-chat overrides",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "explicit_only": {
                "type": "boolean",
                "description": "Override the global explicit_only setting for this chat"
              }
            }
          },
          "default": {}
        }
      }
    },
    "ai": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1,
          "description": "AI provider identifier"
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "description": "AI model identifier"
        }
      }
    },
    "sandbox": {
      "type": "string",
      "description": "Either 'host' or a docker target in the form 'docker:<name>'",
      "oneOf": [
        { "const": "host" },
        { "type": "string", "pattern": "^docker:" }
      ]
    }
  }
}
